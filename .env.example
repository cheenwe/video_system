# 基础平台 - 环境变量示例
# 复制为 .env 后按需修改：cp .env.example .env

# Docker 构建：国内默认 huawei（华为云 APT 镜像）；海外可设 off 使用官方源
# APT_MIRROR=huawei

# 上传后自动转码 MOV/MKV 等为 MP4(H.264+AAC)；需安装 ffmpeg（Docker 镜像已包含）
# VIDEO_TRANSCODE_ENABLED=true

# ---------- 服务 ----------
HOST=0.0.0.0
PORT=8808
# 容器内与 uvicorn 一致；docker-compose 可用 APP_PORT 覆盖
APP_PORT=8808
# 生产 worker 数；>1 时备份邮件请改用 cron（见 docs/deploy.md）
WEB_CONCURRENCY=1
# 仅 DEBUG=true 时开启 /docs、/redoc、/openapi.json；生产请设为 false
DEBUG=true

# ---------- 数据库 ----------
# 本地 SQLite 示例
# DATABASE_URL=sqlite:///./data/lab_system.db
#
# MySQL 示例（本地直连）
# DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/lab_system?charset=utf8mb4
DATABASE_URL=sqlite:///./data/lab_system.db

# Docker Compose MySQL 参数（mysql / prod profile）
MYSQL_PUBLISH_PORT=3306
MYSQL_HOST=mysql
MYSQL_PORT=3306
WAIT_FOR_DB=true
DB_WAIT_TIMEOUT=90
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=lab_system
MYSQL_USER=lab_user
MYSQL_PASSWORD=lab_pass

# ---------- Redis（Docker Compose 随 sqlite/mysql/prod 启动；本地非 Docker 可留空禁用）----------
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=
REDIS_PUBLISH_PORT=6379
WAIT_FOR_REDIS=false
REDIS_WAIT_TIMEOUT=30

# ---------- 文件（须为本地目录；Docker 默认 /app/uploads 并挂载宿主机 ./uploads）----------
UPLOAD_ROOT=uploads
VIDEO_MAX_UPLOAD_MB=5120
VIDEO_CHUNK_SIZE_MB=5
# 是否允许游客播放公开视频（false 时所有播放均需登录）
VIDEO_ALLOW_ANONYMOUS_PLAY=true
VIDEO_COMMENT_GUEST_PREVIEW=2

# ---------- JWT ----------
SECRET_KEY=app-platform-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ---------- 默认管理员（仅首次无用户时创建） ----------
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin2026

# ---------- CORS ----------
CORS_ORIGINS=*

# ---------- 登录安全 ----------
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCK_SECONDS=600

# ---------- 定时数据库备份 + SMTP 邮件 ----------
# 设为 true 时：单进程 uvicorn 下由应用内 APScheduler 每天定时执行；多 worker 建议用系统 cron 调用：
#   .venv/bin/python -m src.jobs.run_backup_email
# 备份附件格式为 ZIP（内含 MySQL .sql 或 SQLite .db）
BACKUP_EMAIL_ENABLED=false
BACKUP_HOUR=3
BACKUP_MINUTE=0
BACKUP_TIMEZONE=Asia/Shanghai
MYSQLDUMP_PATH=mysqldump
BACKUP_EMAIL_TO=
BACKUP_KEEP_LOCAL_COPY=false
BACKUP_LOCAL_DIR=uploads/db_backups
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
